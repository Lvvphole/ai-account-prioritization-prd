{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvalResult",
  "type": "object",
  "required": [
    "eval_name",
    "status",
    "score",
    "failures"
  ],
  "properties": {
    "eval_name": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "blocked"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
