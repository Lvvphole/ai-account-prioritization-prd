{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Recommendation",
  "type": "object",
  "required": [
    "id",
    "agent_run_id",
    "account_id",
    "owner_id",
    "score",
    "confidence",
    "reason_codes",
    "source_signals",
    "next_best_action",
    "verification_status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "agent_run_id": {
      "type": "string"
    },
    "account_id": {
      "type": "string"
    },
    "owner_id": {
      "type": "string"
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source_signals": {
      "type": "array",
      "minItems": 1
    },
    "next_best_action": {
      "type": "string",
      "minLength": 1
    },
    "verification_status": {
      "enum": [
        "passed",
        "failed",
        "blocked_review_required"
      ]
    }
  }
}
